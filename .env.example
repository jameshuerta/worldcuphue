# Hue bridge connection — copy HUE_BRIDGE_IP and HUE_USERNAME from your
# nsc-hue/.env (same bridge, same account).
HUE_BRIDGE_IP=
HUE_USERNAME=

# Set to "remote" only if running from outside your home network
# (requires node hue-remote-setup.js). Omit or "local" for home use.
HUE_MODE=local
HUE_CLIENT_ID=
HUE_CLIENT_SECRET=
HUE_ACCESS_TOKEN=
HUE_REFRESH_TOKEN=

# Light IDs for the left and right lamps (from your Hue app / bridge).
HUE_LIGHT_LEFT=7
HUE_LIGHT_RIGHT=5

# Don't start tracking a new match after this hour, Central Time (24h clock).
# A match already in progress is allowed to finish.
CUTOFF_HOUR_CT=22

# For the first match of the day only, turn the lamps on this many minutes
# before kickoff (using the teams' general colors as a preview).
EARLY_LAMP_MINS=60

# Goal flash pattern: strobe | pulse | colorshift
GOAL_FLASH_PATTERN=strobe
GOAL_FLASH_COUNT=6
